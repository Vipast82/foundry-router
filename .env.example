# Foundry Router — secrets and environment overrides.
# Copy to .env next to docker-compose.yml. Never commit the real .env.
# Values here are referenced from config.yaml as ${VAR_NAME} and expanded at load time.

# API key/token for the Meridian bridge (Claude Pro/Max via subscription).
# Leave blank if your Meridian instance does not require one.
MERIDIAN_API_KEY=changeme

# OpenRouter API key — only needed if you register an OpenRouter backend
# or want authenticated model-metadata polling. The public model-listing
# endpoint used by the registry works without a key.
OPENROUTER_API_KEY=

# LiteLLM proxy key — only needed when backend_pool.mode is "litellm".
LITELLM_KEY=

# Port the service listens on (documented default: 11435 — Ollama-adjacent,
# deliberately not 11434 so it can coexist with a real Ollama on the same host).
FOUNDRY_PORT=11435

# Host interface to bind INSIDE the container. Keep 0.0.0.0 in Docker (the
# docker-compose port mapping is what controls actual LAN exposure).
FOUNDRY_HOST=0.0.0.0
